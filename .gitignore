# ─── Secrets — signing certs & keys (NEVER commit) ─────────────────────────────
# *.p12
# *.p8
# *.pem
# *.key
# *.cer
# *.certSigningRequest
# *.mobileprovision
# *.provisionprofile

# ─── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ─── macOS code-signing artifacts (regenerated when the .app is signed) ────────
**/_CodeSignature/

# ─── Go native host build outputs (regenerated by host-go/build.sh and CI) ─────
host-go/dist/*
!host-go/dist/.gitkeep

# ─── Installer build outputs (regenerated by the build scripts and CI) ─────────
installers/*/dist/
installers/linux/payload/
installers/linux/payload-un/
installers/windows/Output/
*.pkg
*.dmg
*.exe
*.deb

# ─── Editor / IDE / misc ───────────────────────────────────────────────────────
*.swp
*.swo
*~
*.log
.idea/
.vscode/
Thumbs.db
