# ─── Secrets — signing certs & keys (NEVER commit) ─────────────────────────────
# *.p12
# *.p8
# *.pem
# *.key
# *.cer
# *.certSigningRequest
# *.mobileprovision
# *.provisionprofile

# ─── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ─── macOS code-signing artifacts (regenerated when the .app is signed) ────────
**/_CodeSignature/

# ─── Rust installer build outputs (regenerated by cargo / CI) ──────────────────
installers/rust/target/
# NOTE: installers/rust/Cargo.lock is committed on purpose — it pins a
# reproducible build for the distributable installer binary.

# ─── Installer / packaging build outputs (regenerated by CI) ───────────────────
installers/*/dist/
*.pkg
*.dmg
*.exe
*.deb
*.msi

# ─── Editor / IDE / misc ───────────────────────────────────────────────────────
*.swp
*.swo
*~
*.log
.idea/
.vscode/
Thumbs.db
